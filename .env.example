# Google API Credentials
# Path to the service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=credentials.json

# Google Sheet Details
# The ID is the long string in the sheet URL: https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
SPREADSHEET_ID=your_google_sheet_id_here

# External APIs
GEMINI_API_KEY=your_gemini_api_key_here
WHAPI_TOKEN=your_whapi_token_here

# Ollama (Local AI for Document Vision)
# Install Ollama: https://ollama.com
# Pull Moondream: ollama pull moondream
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=moondream

# Founder Phone (for WhatsApp notifications)
# Format: +61412345678
FOUNDER_PHONE=+61your_phone_number
