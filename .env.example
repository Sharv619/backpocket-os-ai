# BackPocket OS - Environment Variables Template
# Copy to .env and fill in your values. NEVER commit .env to git.

# ── Owner Persona — Sovereign Engine ────────────────────────────────────────
# Personalises all AI-generated emails and responses.
# NSW Govt / investor demos: use a role title instead of a personal name.
BP_OWNER_NAME=YourName
BP_BUSINESS_TYPE=construction  # e.g. construction, consulting, government

# ── Google API ───────────────────────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=credentials.json
SPREADSHEET_ID=your_google_sheet_id_here

# ── AI APIs ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Ollama (Local AI / Document Vision) ──────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=moondream

# ── WhatsApp (WHAPI) ─────────────────────────────────────────────────────────
WHAPI_TOKEN=your_whapi_token_here
FOUNDER_PHONE=+61your_phone_number

# ── Supabase Auth (EPIC F) ───────────────────────────────────────────────────
# Dashboard: app.supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
# Dashboard: Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# ── API Security ─────────────────────────────────────────────────────────────
# Protects all /api/* endpoints — set a strong random string, add to headers
BP_API_KEY=change_me_generate_with_python_secrets_token_hex_16\n\n# Token encryption (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")\nBP_ENCRYPTION_KEY=
# HMAC secret shared with WHAPI webhook — set same value in WHAPI dashboard
WHAPI_WEBHOOK_SECRET=change_me_generate_with_python_secrets_token_hex_16

# ── Demo Mode ────────────────────────────────────────────────────────────────
# Set to 1 to skip real Gmail/WhatsApp sends (safe for live demos)
DEMO_MODE=0

# ── Server Bind (LAN access for mobile device) ──────────────────────────────
# 0.0.0.0 = bind all interfaces (required for Android to reach dev box)
BP_HOST=0.0.0.0
BP_PORT=8000

# ── Postgres (Data Migration epic) ──────────────────────────────────────────
# Used by services/postgres_db.py + scripts/sqlite_to_pg_migration.py
# Format: postgresql+psycopg2://USER:PASS@HOST:PORT/DB
POSTGRES_DB_URL=postgresql+psycopg2://backpocket_user:backpocket_password@localhost:5432/backpocket_db
SQL_ECHO=false
