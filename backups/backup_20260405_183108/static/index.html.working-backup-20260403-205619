<script>
// ===== STATE =====
let currentSection = null;
let approvedItems = new Set();
let pendingEmails = [];
let pendingDocs = [];
let pendingMarketing = [];
let pendingTasks = [];
let chatHistory = [];

// ===== INIT =====
document.addEventListener('DOMContentLoaded', () => {
  setGreeting();
  loadData();
  loadConversations();
});

// ===== CONVERSATIONS =====
async function loadConversations() {
  try {
    const res = await fetch('/api/conversations');
    const data = await res.json();
    const allConvs = data.conversations || [];
    
    const twinList = document.getElementById('twin-chat-list');
    const openList = document.getElementById('open-chat-list');
    
    const twinConvs = allConvs.filter(c => c.source === 'twin').slice(0, 5);
    const openConvs = allConvs.filter(c => c.source === 'opencode').slice(0, 5);
    
    if (twinConvs.length === 0) {
      twinList.innerHTML = '<div class="chat-history-empty">No twin chats</div>';
    } else {
      twinList.innerHTML = twinConvs.map(conv => `
        <div class="chat-history-item" onclick="loadConversation('${conv.id}')">
          <div class="chat-history-item-title">${conv.title || 'New Chat'}</div>
          <div class="chat-history-item-time">${formatTime(conv.updated_at)}</div>
        </div>
      `).join('');
    }
    
    if (openConvs.length === 0) {
      openList.innerHTML = '<div class="chat-history-empty">No open chats</div>';
    } else {
      openList.innerHTML = openConvs.map(conv => `
        <div class="chat-history-item" onclick="loadConversation('${conv.id}')">
          <div class="chat-history-item-title">${conv.title || 'New Chat'}</div>
          <div class="chat-history-item-time">${formatTime(conv.updated_at)}</div>
        </div>
      `).join('');
    }
  } catch (e) {
    console.error('Failed to load conversations:', e);
  }
}

function formatTime(timestamp) {
  if (!timestamp) return '';
  const date = new Date(timestamp);
  const now = new Date();
  const diff = now - date;
  if (diff < 60000) return 'Just now';
  if (diff < 3600000) return Math.floor(diff / 60000) + 'm ago';
  if (diff < 86400000) return Math.floor(diff / 3600000) + 'h ago';
  return date.toLocaleDateString();
}

async function loadConversation(convId) {
  try {
    const res = await fetch('/api/conversations/' + convId);
    const data = await res.json();
    const messages = data.messages || [];
    const chatMsgs = document.getElementById('chat-messages');
    chatMsgs.innerHTML = messages.map(m => `
      <div class="chat-msg ${m.role}">${m.content}</div>
    `).join('');
    chatMsgs.scrollTop = chatMsgs.scrollHeight;
    expandChat();
  } catch (e) {
    console.error('Failed to load conversation:', e);
  }
}

// ===== MAGNIFIER =====
let magnifierActive = false;

function toggleMagnifier() {
  magnifierActive = !magnifierActive;
  document.body.classList.toggle('magnifier-on', magnifierActive);
  document.querySelector('.magnifier-btn').classList.toggle('active', magnifierActive);
}

// ===== GREETING =====
function setGreeting() {
  const hour = new Date().getHours();
  let greeting = 'Good evening';
  if (hour < 12) greeting = 'Good morning';
  else if (hour < 17) greeting = 'Good afternoon';
  document.getElementById('greeting').textContent = `${greeting}, Cherry.`;
}

// ===== SIDEBAR =====
function toggleSidebar() {
  const sidebar = document.getElementById('sidebar');
  sidebar.classList.toggle('expanded');
}

// Auto-collapse sidebar when clicking outside
document.addEventListener('click', function(e) {
  const sidebar = document.getElementById('sidebar');
  const toggle = document.querySelector('.sidebar-toggle');
  if (!sidebar.contains(e.target) && !toggle.contains(e.target)) {
    sidebar.classList.remove('expanded');
  }
});

function toggleNav(el, subId) {
  const sub = document.getElementById(subId);
  sub.classList.toggle('open');
  
  // Auto-expand sidebar when clicking nav with sub-items
  const sidebar = document.getElementById('sidebar');
  sidebar.classList.add('expanded');
  
  // Close other submenus
  document.querySelectorAll('.nav-subitems').forEach(s => {
    if (s.id !== subId) s.classList.remove('open');
  });
}

function setActivePage(page, el) {
  document.querySelectorAll('.nav-item').forEach(item => item.classList.remove('active'));
  if (el) el.classList.add('active');
}

// ===== DATA =====
async function loadData() {
  try {
    const response = await fetch('/api/pending');
    const data = await response.json();
    
    pendingEmails = data.items.map(item => ({
      id: item.ref_id,
      title: item.subject || 'No subject',
      time: formatTimeAgo(item.created_at),
      type: 'email',
      from: item.sender,
      ref_id: item.ref_id,
      tier: item.tier
    }));
  } catch (err) {
    console.error('Failed to load pending emails:', err);
    pendingEmails = [];
  }
  
  pendingDocs = [];
  pendingMarketing = [];
  pendingTasks = [];
  
  document.getElementById('email-count').textContent = pendingEmails.length;
  document.getElementById('stat-email-count').textContent = pendingEmails.length;
  document.getElementById('stat-doc-count').textContent = pendingDocs.length;
  document.getElementById('stat-marketing-count').textContent = pendingMarketing.length;
  document.getElementById('stat-task-count').textContent = pendingTasks.length;
  
  updateTotalCount();
  renderAllLists();
}

function formatTimeAgo(dateStr) {
  const date = new Date(dateStr.replace(' ', 'T'));
  const now = new Date();
  const diffMs = now - date;
  const diffMins = Math.floor(diffMs / 60000);
  const diffHours = Math.floor(diffMs / 3600000);
  const diffDays = Math.floor(diffMs / 86400000);
  
  if (diffMins < 60) return `${diffMins}m ago`;
  if (diffHours < 24) return `${diffHours}h ago`;
  return `${diffDays}d ago`;
}

function updateTotalCount() {
  const total = pendingEmails.length + pendingDocs.length + pendingMarketing.length + pendingTasks.length;
  document.getElementById('total-count').textContent = `${total} items`;
}

function renderAllLists() {
  renderList('email', pendingEmails);
  renderList('docs', pendingDocs);
  renderList('marketing', pendingMarketing);
  renderList('tasks', pendingTasks);
}

function renderList(type, items) {
  const list = document.getElementById(`${type}-list`);
  const filtered = items.filter(i => !approvedItems.has(i.id));
  
  if (filtered.length === 0) {
    list.classList.remove('show');
    return;
  }
  
  list.innerHTML = filtered.map(item => `
    <div class="expanded-item" onclick="openModal('${item.id}', '${item.type}')">
      <div class="expanded-item-left">
        <div class="expanded-checkbox"></div>
        <span class="expanded-title">${item.title}</span>
      </div>
      <span class="expanded-time">${item.time}</span>
    </div>
  `).join('');
}

// ===== SOPs =====
let allSOPs = [];

function loadSOPs() {
  fetch('/api/sops')
    .then(r => r.json())
    .then(data => {
      allSOPs = data.sops || [];
      renderSOPs('all');
    })
    .catch(e => {
      document.getElementById('sops-list').innerHTML = '<div class="sops-loading">Error loading SOPs</div>';
    });
}

function loadEmailRules() {
  fetch('/api/email-rules')
    .then(r => r.json())
    .then(data => {
      const container = document.getElementById('email-rules-content');
      
      let html = `
