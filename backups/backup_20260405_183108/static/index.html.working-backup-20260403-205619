function discussEmailRules() {
  const message = `I want to discuss the email triage rules. Can you explain how the tier system works and suggest any improvements?`;
  
  // Open chat and ask Twin
  document.getElementById('email-rules-section').style.display = 'none';
  expandChat();
  
  setTimeout(() => {
    document.getElementById('chat-input').value = message;
    sendChat();
  }, 300);
}

function requestEmailRuleChange() {
  const suggestion = prompt('What change would you like to make to the email rules?\n\nExample: "Add XYZ sender to Tier 1" or "Change tier 4 to..."');
  
  if (!suggestion || !suggestion.trim()) return;
  
  // Save as an instruction for review (inactive until approved)
  fetch('/api/instructions', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({
      instruction_text: `EMAIL RULE CHANGE REQUEST: ${suggestion}`,
      category: 'email_rules_change',
      is_active: false,
      is_critical: true,
      description: 'Pending review - change to email triage rules'
    })
  }).then(r => r.json()).then(data => {
    if (data.status === 'success') {
      alert('Change request saved! It will be reviewed before being applied to the system. You can discuss this with Twin in the chat.');
    }
  });
}

function loadTwinInstructions() {
  fetch('/api/instructions')
    .then(r => r.json())
    .then(data => {
      const container = document.getElementById('twin-instructions-list');
