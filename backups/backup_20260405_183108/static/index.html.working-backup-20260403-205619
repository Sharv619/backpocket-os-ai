<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BackPocket OS — My Twin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    :root {
      --cream: #FAF7F2;
      --terracotta: #C87941;
      --sage: #8FAE8B;
      --brown: #1A1613;
      --shadow-soft: 0 4px 20px -2px rgba(26, 22, 19, 0.05);
      --shadow-soft-lg: 0 10px 30px -5px rgba(26, 22, 19, 0.08);
      --font-base: 1rem;
      --font-sm: 0.875rem;
      --font-xs: 0.75rem;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    
    body {
      font-family: 'Outfit', -apple-system, sans-serif;
      background-color: var(--cream);
      color: var(--brown);
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ===== LAYOUT ===== */
    .app-container {
      display: flex;
      width: 100%;
      height: 100vh;
      position: relative;
      overflow: hidden;
    }

    main.main-content {
      flex: 1;
      overflow-y: auto;
      overflow-x: hidden;
    }

    /* ===== BACKGROUND ===== */
    .bg-image {
      position: fixed;
      inset: 0;
      z-index: -2;
      background-image: url('https://cdn.magicpatterns.com/uploads/76Y3pPQrQBD9mh2J2KL6YC/background_dashboard.png');
      background-size: cover;
      background-position: center;
      opacity: 0.5;
    }

    .bg-overlay {
      position: fixed;
      inset: 0;
      z-index: -1;
      background: rgba(250, 247, 242, 0.3);
      backdrop-filter: blur(2px);
    }

    .frosted-glass {
      background: rgba(255, 255, 255, 0.45) !important;
      backdrop-filter: blur(12px) !important;
      -webkit-backdrop-filter: blur(12px) !important;
      border: 1px solid rgba(255, 255, 255, 0.3) !important;
    }

    /* ===== MAGNIFIER ===== */
    .magnifier-on .app-container {
      zoom: 1.15;
      width: 87%; /* Compensate for zoom width shift */
    }
    
    @media (max-width: 768px) {
      .magnifier-on .app-container {
        zoom: 1.05;
        width: 95%;
      }
    }

    /* ===== SIDEBAR ===== */
    .sidebar {
      width: 72px;
      height: 100%;
      background: var(--brown);
      display: flex;
      flex-direction: column;
      flex-shrink: 0;
      position: relative;
      z-index: 20;
      transition: width 0.3s ease;
      overflow: hidden;
    }

    .sidebar:hover, .sidebar.expanded {
      width: 260px;
    }

    .sidebar-header {
      height: 64px;
      display: flex;
      align-items: center;
      padding: 0 16px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      flex-shrink: 0;
    }

    .sidebar-toggle {
      background: none;
      border: none;
      color: rgba(250, 247, 242, 0.7);
      cursor: pointer;
      padding: 8px;
      border-radius: 8px;
      transition: all 0.2s;
      flex-shrink: 0;
    }

    .sidebar-toggle:hover {
      background: rgba(255, 255, 255, 0.05);
      color: var(--cream);
    }

    .sidebar-logo {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-left: 8px;
      white-space: nowrap;
      overflow: hidden;
      opacity: 0;
      transition: opacity 0.3s;
    }

    .sidebar:hover .sidebar-logo,
    .sidebar.expanded .sidebar-logo {
      opacity: 1;
    }

    .sidebar-logo-icon {
      color: var(--terracotta);
      font-size: 22px;
      flex-shrink: 0;
    }

    .sidebar-logo-text {
      font-weight: 600;
      font-size: 14px;
      color: var(--cream);
      letter-spacing: 0.5px;
    }

    .sidebar-nav {
      flex: 1;
      overflow-y: auto;
      overflow-x: hidden;
      padding: 16px 8px;
    }

    .nav-item {
      display: flex;
      align-items: center;
      padding: 10px 12px;
      border-radius: 8px;
      cursor: pointer;
      transition: all 0.2s;
      color: rgba(250, 247, 242, 0.7);
      margin-bottom: 2px;
      white-space: nowrap;
    }

    .nav-item:hover {
      background: rgba(255, 255, 255, 0.05);
      color: var(--cream);
    }

    .nav-item.active {
      background: rgba(200, 121, 65, 0.2);
      color: var(--terracotta);
    }

    .nav-item-icon {
      width: 36px;
      height: 36px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      border-radius: 8px;
      background: rgba(255, 255, 255, 0.05);
      transition: all 0.2s;
    }

    .nav-item:hover .nav-item-icon,
    .nav-item.active .nav-item-icon {
      background: rgba(200, 121, 65, 0.2);
    }

    .nav-item-icon svg {
      width: 18px;
      height: 18px;
    }

    .nav-item-label {
      flex: 1;
      font-size: var(--font-sm);
      font-weight: 700;
      letter-spacing: 0.5px;
      white-space: nowrap;
      overflow: hidden;
      margin-left: 12px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      opacity: 0;
      transition: opacity 0.3s;
    }

    .sidebar:hover .nav-item-label,
    .sidebar.expanded .nav-item-label {
      opacity: 1;
    }

    .nav-badge {
      background: var(--terracotta);
      color: white;
      font-size: 10px;
      padding: 2px 6px;
      border-radius: 10px;
      margin-left: 8px;
    }

    .nav-new-badge {
      background: var(--terracotta);
      color: white;
      font-size: 9px;
      padding: 2px 5px;
      border-radius: 4px;
      font-weight: 700;
      margin-left: 8px;
    }

    .nav-chevron {
      font-size: 12px;
      opacity: 0;
      transition: opacity 0.3s;
    }

    .sidebar:hover .nav-chevron,
    .sidebar.expanded .nav-chevron {
      opacity: 0.7;
    }

    /* Sub-items */
    .nav-subitems {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease;
      margin-left: 12px;
      border-left: 1px solid rgba(255, 255, 255, 0.1);
      padding-left: 0;
    }

    .nav-subitems.open {
      max-height: 300px;
      padding-left: 8px;
    }

    .nav-subitem {
      padding: 10px 12px 10px 16px;
      font-size: var(--font-sm);
      color: rgba(250, 247, 242, 0.7);
      cursor: pointer;
      transition: all 0.2s;
      white-space: nowrap;
      border-radius: 6px;
      margin: 2px 0;
    }

    .nav-subitem:hover {
      color: var(--cream);
      background: rgba(255, 255, 255, 0.1);
    }

    /* Chat History Section */
    .chat-history-section {
      padding: 8px 12px;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      margin-top: 8px;
    }

    .chat-history-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 8px;
    }

    .chat-history-title {
      font-size: var(--font-xs);
      font-weight: 700;
      color: rgba(250, 247, 242, 0.4);
      letter-spacing: 0.5px;
    }

    .chat-history-refresh {
      background: none;
      border: none;
      color: rgba(250, 247, 242, 0.4);
      cursor: pointer;
      padding: 4px;
      border-radius: 4px;
      transition: all 0.2s;
    }

    .chat-history-refresh:hover {
      color: var(--cream);
      background: rgba(255, 255, 255, 0.05);
    }

    .chat-history-refresh svg {
      width: 14px;
      height: 14px;
    }

    .chat-history-list {
      max-height: 180px;
      overflow-y: auto;
    }

    .chat-history-empty {
      font-size: var(--font-xs);
      color: rgba(250, 247, 242, 0.3);
      padding: 8px 0;
      text-align: center;
    }

    .chat-history-item {
      padding: 8px 10px;
      border-radius: 6px;
      cursor: pointer;
      margin-bottom: 4px;
      transition: all 0.2s;
      background: rgba(255, 255, 255, 0.03);
    }

    .chat-history-item:hover {
      background: rgba(255, 255, 255, 0.08);
    }

    .chat-history-item-title {
      font-size: var(--font-xs);
      color: rgba(250, 247, 242, 0.7);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .chat-history-item-time {
      font-size: 10px;
      color: rgba(250, 247, 242, 0.3);
      margin-top: 2px;
    }

    /* Magnifier Section */
    .magnifier-section {
      padding: 8px 0;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      margin-top: 8px;
    }

    .magnifier-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 10px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 8px;
      color: rgba(250, 247, 242, 0.7);
      cursor: pointer;
      transition: all 0.2s;
    }

    .magnifier-btn:hover {
      background: rgba(255, 255, 255, 0.1);
      color: var(--cream);
    }

    .magnifier-btn.active {
      background: var(--terracotta);
      border-color: var(--terracotta);
      color: white;
    }

    .magnifier-btn svg {
      width: 18px;
      height: 18px;
    }

    .magnifier-btn span {
      display: none;
    }

    .sidebar.expanded .magnifier-btn span {
      display: inline;
      margin-left: 8px;
      font-size: 12px;
      font-weight: 600;
    }

    .sidebar.expanded .magnifier-btn {
      justify-content: flex-start;
      padding: 10px 12px;
    }

    /* Magnifier in main content */
    .main-magnifier {
      position: fixed;
      top: 24px;
      right: 24px;
      z-index: 100;
    }

    .main-magnifier-btn {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: var(--cream);
      border: 2px solid var(--brown);
      color: var(--brown);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 4px 16px rgba(26, 22, 19, 0.2);
      transition: all 0.2s;
    }

    .main-magnifier-btn:hover {
      transform: scale(1.05);
      box-shadow: 0 6px 20px rgba(26, 22, 19, 0.3);
    }

    .main-magnifier-btn.active {
      background: var(--terracotta);
      border-color: var(--terracotta);
      color: white;
    }

    .main-magnifier-btn svg {
      width: 22px;
      height: 22px;
    }

    /* Magnifier tooltip */
    .main-magnifier-btn::after {
      content: 'Toggle Magnifier';
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%);
      margin-top: 8px;
      padding: 6px 10px;
      background: var(--brown);
      color: var(--cream);
      font-size: 11px;
      border-radius: 6px;
      white-space: nowrap;
      opacity: 0;
      transition: opacity 0.2s;
      pointer-events: none;
    }

    .main-magnifier-btn:hover::after {
      opacity: 1;
    }

    .welcome-section {
      position: relative;
      z-index: 5;
      margin: 32px 0 16px 0;
      padding-top: 48px;
    }

    .welcome-title {
      font-size: 32px;
      font-weight: 700;
      color: var(--brown);
      margin-bottom: 4px;
      letter-spacing: -0.5px;
    }

    .welcome-subtitle {
      font-size: 14px;
      color: rgba(26, 22, 19, 0.5);
      font-weight: 500;
    }

    .stats-row {
      position: relative;
      z-index: 5;
      display: flex;
      gap: 24px;
      align-items: center;
      margin: 24px 0 32px 0;
    }

    .content-wrapper {
      padding: 0 48px 48px 48px;
      max-width: 640px;
    }

    .stat-pill {
      background: none;
      border: none;
      padding: 0;
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 13px;
      font-weight: 600;
      color: rgba(26, 22, 19, 0.5);
      cursor: pointer;
      transition: all 0.2s;
    }

    .stat-pill:hover, .stat-pill.active {
      color: var(--brown);
    }

    .stat-pill::after {
      content: '';
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background: var(--terracotta);
      margin-left: 4px;
      opacity: 0.6;
    }

    .stat-pill.active::after {
      opacity: 1;
    }

    .stat-icon {
      width: 14px;
      height: 14px;
    }

    .chat-section {
      position: relative;
      z-index: 10;
      max-width: 440px; /* Narrower to match design and reveal avatar */
      margin-top: 32px;
    }

    .instructions-section {
      position: relative;
      z-index: 50;
      background: rgba(255, 255, 255, 0.3) !important;
      backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.2);
      box-shadow: none;
      border-radius: 16px;
      margin-top: 24px;
      max-width: 440px; /* Narrower */
      overflow: hidden;
    }

    #total-count {
      color: var(--terracotta);
      font-weight: 700;
    }

    /* Professional Icon Colors */
    #stat-emails .stat-icon { color: var(--sage); }
    #stat-docs .stat-icon { color: rgba(26, 22, 19, 0.4); }
    #stat-marketing .stat-icon { color: var(--terracotta); }
    #stat-tasks .stat-icon { color: var(--sage); }

    .avatar-container {
      position: absolute;
      right: 10%;
      top: 50%;
      transform: translateY(-50%);
      width: 30%;
      max-width: 380px;
      z-index: 1;
      pointer-events: none;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .avatar-img {
      width: 100%;
      height: auto;
      max-height: 75vh;
      object-fit: contain;
      object-position: center bottom;
      mix-blend-mode: multiply;
      filter: saturate(1.1) contrast(1.05);
    }

    /* ===== CHAT SECTION ===== */
    .chat-section {
      position: relative;
      z-index: 10;
      max-width: 440px;
      margin-top: 24px;
    }

    .chat-collapsed {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 18px;
      background: rgba(255, 255, 255, 0.35);
      backdrop-filter: blur(10px);
      border-radius: 12px;
      border: 1px solid rgba(255, 255, 255, 0.2);
      cursor: pointer;
      transition: all 0.25s ease;
      box-shadow: none;
    }

    .chat-collapsed:hover {
      background: white;
      box-shadow: var(--shadow-soft-lg);
      transform: translateY(-2px);
    }

    .chat-icon-wrapper {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: var(--terracotta);
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
    }

    .chat-icon-wrapper svg {
      width: 20px;
      height: 20px;
    }

    .chat-text {
      flex: 1;
    }

    .chat-title {
      font-size: 15px;
      font-weight: 600;
      color: var(--brown);
    }

    .chat-subtitle {
      font-size: 12px;
      color: rgba(26, 22, 19, 0.5);
    }

    .chat-status {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      color: var(--sage);
      font-weight: 500;
    }

    .chat-status-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--sage);
    }

    .chat-expanded {
      background: rgba(255, 255, 255, 0.45);
      backdrop-filter: blur(20px);
      border-radius: 16px;
      border: 1px solid rgba(255, 255, 255, 0.2);
      overflow: hidden;
      box-shadow: none;
      display: none;
    }

    .chat-expanded.show {
      display: block;
      animation: slideUp 0.3s ease;
    }

    @keyframes slideUp {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .chat-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 18px;
      background: var(--brown);
      border-bottom: none;
    }

    .chat-header-left {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .chat-header-icon {
      color: var(--cream);
    }

    .chat-header-icon svg {
      width: 22px;
      height: 22px;
    }

    .chat-header-title {
      font-size: 15px;
      font-weight: 600;
      color: var(--cream);
    }

    .chat-header-status {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      color: var(--sage);
      font-weight: 500;
      margin-left: 8px;
    }

    .chat-close {
      background: none;
      border: none;
      color: rgba(250, 247, 242, 0.6);
      cursor: pointer;
      padding: 8px;
      border-radius: 8px;
      font-size: 18px;
      transition: all 0.2s;
    }

    .chat-close:hover {
      background: rgba(255, 255, 255, 0.1);
      color: var(--cream);
    }

    .chat-messages {
      height: 300px;
      overflow-y: auto;
      padding: 16px;
      background: var(--cream);
    }

    .chat-msg {
      max-width: 85%;
      padding: 12px 16px;
      border-radius: 16px;
      font-size: 14px;
      line-height: 1.5;
      margin-bottom: 12px;
    }

    .chat-msg.ai {
      background: white;
      color: var(--brown);
      border-bottom-left-radius: 4px;
      box-shadow: 0 2px 8px rgba(26, 22, 19, 0.06);
    }

    .chat-msg.user {
      background: var(--brown);
      color: var(--cream);
      border-bottom-right-radius: 4px;
      margin-left: auto;
    }

    .chat-input-area {
      padding: 14px;
      background: white;
      border-top: 1px solid rgba(26, 22, 19, 0.08);
    }

    .chat-input-row {
      display: flex;
      align-items: center;
      gap: 8px;
      background: var(--cream);
      border-radius: 24px;
      padding: 6px 8px 6px 16px;
      border: 1px solid rgba(26, 22, 19, 0.08);
    }

    .chat-input {
      flex: 1;
      background: transparent;
      border: none;
      padding: 10px 12px;
      font-size: 14px;
      color: var(--brown);
      outline: none;
    }

    .chat-input::placeholder {
      color: rgba(26, 22, 19, 0.4);
    }

    .chat-tool {
      background: none;
      border: none;
      color: rgba(26, 22, 19, 0.4);
      cursor: pointer;
      padding: 8px;
      border-radius: 50%;
      font-size: 14px;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .chat-tool:hover {
      background: rgba(26, 22, 19, 0.06);
      color: var(--brown);
    }

    .chat-tool svg {
      width: 18px;
      height: 18px;
    }

    .chat-send-btn {
      background: var(--brown);
      border: none;
      color: var(--cream);
      cursor: pointer;
      padding: 10px;
      border-radius: 50%;
      font-size: 12px;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 38px;
      height: 38px;
    }

    .chat-send-btn:hover {
      background: var(--terracotta);
    }

    .chat-send-btn svg {
      width: 16px;
      height: 16px;
    }

    .chat-new-chat {
      padding: 10px 14px;
      background: var(--cream);
      border-top: 1px solid rgba(26, 22, 19, 0.06);
    }

    .chat-new-chat-btn {
      background: none;
      border: none;
      color: rgba(26, 22, 19, 0.5);
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 8px 10px;
      border-radius: 8px;
      transition: all 0.2s;
    }

    .chat-new-chat-btn:hover {
      background: rgba(26, 22, 19, 0.05);
      color: var(--brown);
    }

    .chat-new-chat-btn svg {
      width: 14px;
      height: 14px;
    }

    .chat-send-btn:hover {
      background: #b86d38;
    }

    .chat-send-btn svg {
      width: 14px;
      height: 14px;
    }

    /* ===== MODAL ===== */
    .modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(26, 22, 19, 0.2);
      backdrop-filter: blur(4px);
      z-index: 100;
      align-items: center;
      justify-content: center;
    }

    .modal-overlay.show {
      display: flex;
      animation: fadeIn 0.2s ease;
    }

    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    .modal {
      background: white;
      border-radius: 16px;
      box-shadow: var(--shadow-soft-lg);
      max-width: 512px;
      width: 90%;
      max-height: 80vh;
      overflow-y: auto;
    }

    .modal-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 20px;
      border-bottom: 1px solid rgba(26, 22, 19, 0.1);
    }

    .modal-title {
      font-size: 18px;
      font-weight: 600;
      color: var(--brown);
      text-transform: capitalize;
    }

    .modal-close {
      background: none;
      border: none;
      color: rgba(26, 22, 19, 0.4);
      cursor: pointer;
      padding: 4px;
      border-radius: 6px;
      font-size: 20px;
      transition: all 0.2s;
    }

    .modal-close:hover {
      background: rgba(26, 22, 19, 0.05);
      color: var(--brown);
    }

    .modal-body {
      padding: 24px;
    }

    .modal-item-title {
      font-size: 14px;
      font-weight: 500;
      color: var(--brown);
      margin-bottom: 16px;
    }

    .modal-field {
      display: grid;
      grid-template-columns: 80px 1fr;
      gap: 8px;
      font-size: 14px;
      margin-bottom: 16px;
    }

    .modal-field-label {
      color: rgba(26, 22, 19, 0.6);
      font-weight: 500;
    }

    .modal-field-value {
      color: var(--brown);
    }

    .modal-content-box {
      background: var(--cream);
      padding: 16px;
      border-radius: 8px;
      font-size: 14px;
      line-height: 1.6;
      color: var(--brown);
      border: 1px solid rgba(26, 22, 19, 0.05);
      white-space: pre-wrap;
      margin-bottom: 16px;
    }

    .modal-recommendation {
      background: rgba(143, 174, 139, 0.1);
      color: var(--sage);
      padding: 12px 16px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 500;
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 16px;
    }

    .modal-footer {
      padding: 16px 20px;
      background: rgba(250, 247, 242, 0.5);
      border-top: 1px solid rgba(26, 22, 19, 0.1);
      display: flex;
      justify-content: flex-end;
      gap: 8px;
    }

    .modal-btn {
      padding: 8px 16px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s;
      border: none;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .modal-btn svg {
      width: 16px;
      height: 16px;
    }

    .modal-btn.archive {
      background: none;
      color: rgba(26, 22, 19, 0.6);
    }

    .modal-btn.archive:hover {
      color: var(--brown);
    }

    .modal-btn.edit {
      background: none;
      border: 1px solid rgba(26, 22, 19, 0.2);
      color: var(--brown);
    }

    .modal-btn.edit:hover {
      background: rgba(26, 22, 19, 0.05);
    }

    .modal-btn.primary {
      background: var(--terracotta);
      color: white;
    }

    .modal-btn.primary:hover {
      background: #b86d38;
    }

    /* ===== EXPANDED LISTS ===== */
    .expanded-list {
      display: none;
      width: 100%;
      max-width: 440px;
      margin-top: 24px;
      padding: 8px;
      border-radius: 16px;
      z-index: 10;
      background: rgba(255, 255, 255, 0.2);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .expanded-list.show {
      display: block;
      animation: slideDown 0.3s ease;
    }

    @keyframes slideDown {
      from { opacity: 0; transform: translateY(-10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .expanded-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 14px;
      border-radius: 12px;
      cursor: pointer;
      transition: all 0.2s;
      margin-bottom: 4px;
    }

    .expanded-item:hover {
      background: rgba(255, 255, 255, 0.5);
    }

    .expanded-item-left {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .expanded-checkbox {
      width: 16px;
      height: 16px;
      border: 1.5px solid rgba(26, 22, 19, 0.2);
      border-radius: 4px;
      transition: all 0.2s;
    }

    .expanded-item:hover .expanded-checkbox {
      border-color: var(--terracotta);
    }

    .expanded-title {
      font-size: 14px;
      font-weight: 500;
      color: var(--brown);
      transition: color 0.2s;
    }

    .expanded-item:hover .expanded-title {
      color: var(--terracotta);
    }

    .expanded-time {
      font-size: 12px;
      color: rgba(26, 22, 19, 0.4);
      font-weight: 500;
    }

    /* ===== SOP & INSTRUCTION CARDS ===== */
    .sop-card {
      background: rgba(255, 255, 255, 0.6);
      border-radius: 12px;
      padding: 16px;
      margin-bottom: 12px;
      border: 1px solid rgba(255, 255, 255, 0.5);
      cursor: pointer;
      transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .sop-card:hover {
      background: white;
      box-shadow: var(--shadow-soft);
      transform: translateY(-2px);
    }

    .sop-card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 8px;
    }

    .sop-title {
      font-weight: 700;
      color: var(--brown);
      font-size: 15px;
    }

    .sop-category {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--terracotta);
      font-weight: 800;
      background: rgba(200, 121, 65, 0.1);
      padding: 3px 8px;
      border-radius: 6px;
    }

    .sop-critical {
      font-size: 10px;
      text-transform: uppercase;
      color: #ef4444;
      font-weight: 800;
      background: rgba(239, 68, 68, 0.1);
      padding: 3px 8px;
      border-radius: 6px;
    }

    .sop-description {
      font-size: 13px;
      color: rgba(26, 22, 19, 0.7);
      line-height: 1.6;
    }

    .sop-steps {
      margin-top: 12px;
      display: none;
      border-top: 1px solid rgba(26, 22, 19, 0.1);
      padding-top: 12px;
    }

    .sop-card.expanded .sop-steps {
      display: block;
    }

    .sop-step {
      display: flex;
      gap: 10px;
      margin-bottom: 10px;
      font-size: 13px;
      color: var(--brown);
    }

    .sop-step-num {
      width: 20px;
      height: 20px;
      background: var(--brown);
      color: white;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 10px;
      font-weight: 700;
      flex-shrink: 0;
    }

    /* ===== TIER CARDS ===== */
    .tier-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 12px;
      margin-top: 16px;
    }

    .tier-card {
      padding: 16px;
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.5);
      border: 1px solid rgba(255, 255, 255, 0.5);
      transition: all 0.2s;
    }

    .tier-card:hover {
      background: white;
      transform: translateY(-2px);
      box-shadow: var(--shadow-soft);
    }

    .tier-num {
      width: 24px;
      height: 24px;
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 800;
      font-size: 12px;
      margin-bottom: 8px;
    }

    .tier-1 .tier-num { background: #fee2e2; color: #ef4444; }
    .tier-2 .tier-num { background: #fef3c7; color: #d97706; }
    .tier-3 .tier-num { background: #dcfce7; color: #16a34a; }
    .tier-4 .tier-num { background: #f3f4f6; color: #4b5563; }
    .tier-5 .tier-num { background: #f1f5f9; color: #64748b; }

    .tier-title {
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.5px;
      margin-bottom: 4px;
    }

    .tier-desc {
      font-size: 11px;
      color: rgba(26, 22, 19, 0.6);
      line-height: 1.5;
    }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 768px) {
      .sidebar {
