        container.innerHTML = '<div class="sops-loading">No Twin instructions yet. Add instructions to make Twin smarter.</div>';
        return;
      }
      container.innerHTML = general.map(inst => `
        <div class="sop-card">
          <div class="sop-header">
            <span class="sop-category">${inst.category || 'General'}</span>
            ${inst.is_critical ? '<span class="sop-critical">Critical</span>' : ''}
