}

function archiveItem() {
  if (currentItem) {
    approvedItems.add(currentItem.id);
    closeModal();
    updateTotalCount();
    renderAllLists();
  }
}

function approveItem() {
  approvedItems.add(currentItem?.id);
  closeModal();
  updateTotalCount();
  renderAllLists();
  
  // Update indicators
  const remaining = pendingEmails.filter(e => !approvedItems.has(e.id)).length;
  const indicator = document.getElementById('email-indicator');
  indicator.style.display = remaining > 0 ? 'block' : 'none';
  document.getElementById('stat-email-count').textContent = remaining;
  document.getElementById('email-count').textContent = remaining;
}

document.getElementById('modal-overlay').addEventListener('click', (e) => {
  if (e.target.id === 'modal-overlay') closeModal();
});
