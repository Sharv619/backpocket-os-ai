  const text = prompt('Enter new instruction:');
  if (!text) return;
  const category = prompt('Category (general, email, chat, etc.):', 'general') || 'general';
  fetch('/api/instructions', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({instruction_text: text, category: category, is_active: true, is_critical: false})
  }).then(r => r.json()).then(data => {
    if (data.status === 'success') {
      loadTwinInstructions();
    }
  });
}

let currentEditingId = null;

function editInstruction(id, category, text) {
  currentEditingId = id;
  document.getElementById('edit-category').value = category || 'general';
  document.getElementById('edit-instruction-text').value = text;
  document.getElementById('edit-critical').checked = false;
  document.getElementById('edit-preview').textContent = text;
  
  // Update preview on input
  document.getElementById('edit-instruction-text').oninput = function() {
    document.getElementById('edit-preview').textContent = this.value;
  };
  
  document.getElementById('instruction-modal').style.display = 'flex';
}

function closeInstructionModal() {
  document.getElementById('instruction-modal').style.display = 'none';
  currentEditingId = null;
}

function discussInstruction() {
  const text = document.getElementById('edit-instruction-text').value;
  const category = document.getElementById('edit-category').value;
  const isCritical = document.getElementById('edit-critical').checked;
  
  // Instead of closing modal, add chat section to it and ask Twin
  const previewBox = document.getElementById('edit-preview');
  previewBox.innerHTML = '<div class="instruction-chat-loading">Twin is thinking...</div>';
  
  // Ask Twin to review the instruction
  const message = `Please review this instruction and tell me if it's clear and effective. Should I make any changes?\n\nInstruction (${category}${isCritical ? ' - CRITICAL' : ''}):\n${text}`;
  
  fetch('/api/twin-chat', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({message: message, chat_history: []})
  })
  .then(r => r.json())
  .then(data => {
    const response = data.response || 'Twin is thinking...';
    previewBox.innerHTML = `
      <div class="instruction-chat-response">
        <strong>Twin's Feedback:</strong>
        <div style="margin-top: 8px; line-height: 1.6;">${response.replace(/\n/g, '<br>')}</div>
      </div>
    `;
  })
  .catch(e => {
    previewBox.innerHTML = '<div class="instruction-chat-error">Could not reach Twin. Try again.</div>';
  });
}

function saveInstructionEdit() {
  const text = document.getElementById('edit-instruction-text').value;
  const category = document.getElementById('edit-category').value;
  const isCritical = document.getElementById('edit-critical').checked;
  
  if (!text.trim()) {
    alert('Please enter an instruction');
    return;
  }
  
  // Validate instruction before saving
  if (text.length < 10) {
    alert('Instruction is too short. Please provide more detail.');
    return;
  }
  
  if (text.length > 2000) {
    alert('Instruction is too long. Please keep it under 2000 characters.');
    return;
  }
  
  // Show preview and confirm
  const confirmMsg = `Are you sure you want to save this instruction?

Category: ${category}
Critical: ${isCritical ? 'Yes' : 'No'}
Preview: ${text.substring(0, 100)}...

This will be saved and Twin will follow this instruction.`;
  
  if (!confirm(confirmMsg)) {
    return;
  }
  
  fetch('/api/instructions/' + currentEditingId, {
    method: 'PUT',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({
      instruction_text: text, 
      category: category, 
      is_active: true, 
      is_critical: isCritical
    })
  }).then(r => r.json()).then(data => {
    if (data.status === 'success') {
      alert('Instruction saved successfully! Twin will follow this from now on.');
      closeInstructionModal();
      loadTwinInstructions();
    } else {
      alert('Error saving: ' + (data.message || 'Unknown error'));
    }
  });
}

function deleteInstruction(id) {
  if (!confirm('Delete this instruction?')) return;
  fetch('/api/instructions/' + id, {method: 'DELETE'}).then(r => r.json()).then(data => {
    if (data.status === 'success') {
      loadTwinInstructions();
    }
  });
}

function escapeHtml(text) {
  if (!text) return '';
  return text.replace(/'/g, "\\'").replace(/"/g, '&quot;');
}

function loadSenderRules() {
  fetch('/api/sender-instructions')
    .then(r => r.json())
    .then(data => {
      const container = document.getElementById('sender-rules-list');
      const sender = data.instructions || [];
      if (sender.length === 0) {
        container.innerHTML = '<div class="sops-loading">No sender-specific rules yet. Add rules for specific email senders.</div>';
        return;
      }
      container.innerHTML = sender.map(rule => `
        <div class="sop-card">
          <div class="sop-header">
            <span class="sop-category">${rule.category || 'Custom'}</span>
          </div>
          <div class="sop-title">${rule.sender}</div>
          <div class="sop-description">${rule.instructions?.substring(0, 150)}...</div>
        </div>
      `).join('');
    })
    .catch(e => {
      document.getElementById('sender-rules-list').innerHTML = '<div class="sops-loading">Error loading sender rules</div>';
    });
}

function loadClientMaster() {
  fetch('/api/client-master')
    .then(r => r.json())
    .then(data => {
      const container = document.getElementById('client-master-content');
      if (data.status === 'error') {
        container.innerHTML = '<div class="sops-loading">Error loading client data: ' + data.message + '</div>';
        return;
      }
      if (data.status === 'empty' || !data.clients || data.clients.length === 0) {
        container.innerHTML = '<div class="sops-loading">No clients in BPS_Client_Master yet.</div>';
        return;
      }
      container.innerHTML = `
        <div class="client-master-stats">
          <span>${data.count} clients</span>
        </div>
        <div class="client-master-table">
          <table>
            <thead>
              <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Status</th>
                <th>Mobile</th>
                <th>Background</th>
              </tr>
            </thead>
            <tbody>
              ${data.clients.slice(0, 50).map(client => `
                <tr>
                  <td>${client.first_name || ''} ${client.last_name || ''}</td>
                  <td>${client.primary_email || client.email || ''}</td>
                  <td>${client.client_status || ''}</td>
                  <td>${client.mobile || ''}</td>
                  <td>${client.background_info || ''}</td>
                </tr>
              `).join('')}
            </tbody>
          </table>
        </div>
      `;
    })
    .catch(e => {
      document.getElementById('client-master-content').innerHTML = '<div class="sops-loading">Error loading client master</div>';
    });
}

function renderSOPs(category) {
  const container = document.getElementById('sops-list');
  const filtered = category === 'all' ? allSOPs : allSOPs.filter(s => s.category === category);
  
  if (filtered.length === 0) {
    container.innerHTML = '<div class="sops-loading">No SOPs in this category</div>';
    return;
  }
  
  container.innerHTML = filtered.map(sop => {
    const steps = JSON.parse(sop.steps || '[]');
    return `
      <div class="sop-card" onclick="toggleSOP(this)">
        <div class="sop-card-header">
          <span class="sop-title">${sop.title}</span>
          <span class="sop-category">${sop.category}</span>
        </div>
        <div class="sop-description">${sop.description}</div>
        <div class="sop-steps">
          ${steps.map((step, i) => `
            <div class="sop-step">
              <span class="sop-step-num">${i + 1}</span>
              <span>${step.replace(/^\d+\.\s*/, '')}</span>
            </div>
          `).join('')}
        </div>
      </div>
    `;
  }).join('');
}

function toggleSOP(card) {
  card.classList.toggle('expanded');
}

function filterSops(category) {
  document.querySelectorAll('.sop-filter').forEach(f => f.classList.remove('active'));
  event.target.classList.add('active');
  renderSOPs(category);
}

function toggleSection(section) {
  const lists = ['email-list', 'docs-list', 'marketing-list', 'tasks-list'];
  const statIds = ['stat-emails', 'stat-docs', 'stat-marketing', 'stat-tasks'];
  
  const sopsSection = document.getElementById('sops-section');
  const twinSection = document.getElementById('twin-instructions-section');
  const senderSection = document.getElementById('sender-rules-section');
  const emailRulesSection = document.getElementById('email-rules-section');
  const clientMasterSection = document.getElementById('client-master-section');
  
  lists.forEach(id => {
    const el = document.getElementById(id);
    if (id === `${section}-list`) {
      el.classList.toggle('show');
    } else {
      el.classList.remove('show');
    }
  });
  
  if (section === 'sops') {
    sopsSection.style.display = sopsSection.style.display === 'none' ? 'block' : 'none';
    if (sopsSection.style.display === 'block' && allSOPs.length === 0) {
      loadSOPs();
    }
    twinSection.style.display = 'none';
    senderSection.style.display = 'none';
    emailRulesSection.style.display = 'none';
  } else if (section === 'twin-instructions') {
    twinSection.style.display = twinSection.style.display === 'none' ? 'block' : 'none';
    if (twinSection.style.display === 'block') {
      loadTwinInstructions();
    }
    sopsSection.style.display = 'none';
    senderSection.style.display = 'none';
    emailRulesSection.style.display = 'none';
  } else if (section === 'sender-rules') {
    senderSection.style.display = senderSection.style.display === 'none' ? 'block' : 'none';
    if (senderSection.style.display === 'block') {
      loadSenderRules();
    }
    sopsSection.style.display = 'none';
    twinSection.style.display = 'none';
    emailRulesSection.style.display = 'none';
  } else if (section === 'email-rules') {
    emailRulesSection.style.display = emailRulesSection.style.display === 'none' ? 'block' : 'none';
    if (emailRulesSection.style.display === 'block') {
      loadEmailRules();
    }
    sopsSection.style.display = 'none';
    twinSection.style.display = 'none';
    senderSection.style.display = 'none';
    clientMasterSection.style.display = 'none';
  } else if (section === 'client-master') {
    clientMasterSection.style.display = clientMasterSection.style.display === 'none' ? 'block' : 'none';
    if (clientMasterSection.style.display === 'block') {
      loadClientMaster();
    }
    sopsSection.style.display = 'none';
    twinSection.style.display = 'none';
    senderSection.style.display = 'none';
    emailRulesSection.style.display = 'none';
  } else {
    sopsSection.style.display = 'none';
    twinSection.style.display = 'none';
    senderSection.style.display = 'none';
    emailRulesSection.style.display = 'none';
    clientMasterSection.style.display = 'none';
  }
  
  statIds.forEach(id => {
    const el = document.getElementById(id);
    el.classList.toggle('active', id === `stat-${section}`);
  });
  
  currentSection = section;
  
  const avatar = document.getElementById('avatar-container');
  const hasOpenList = lists.some(id => document.getElementById(id).classList.contains('show')) || section === 'sops' || section === 'twin-instructions' || section === 'sender-rules' || section === 'email-rules' || section === 'client-master';
  avatar.classList.toggle('expanded', hasOpenList);
}

// ===== CHAT =====
function expandChat() {
  document.getElementById('chat-collapsed').style.display = 'none';
  document.getElementById('chat-expanded').classList.add('show');
  document.getElementById('avatar-container').classList.add('expanded');
}

function collapseChat() {
  document.getElementById('chat-collapsed').style.display = 'flex';
  document.getElementById('chat-expanded').classList.remove('show');
  
  const anyListOpen = ['email-list', 'docs-list', 'marketing-list', 'tasks-list']
    .some(id => document.getElementById(id).classList.contains('show'));
  
  if (!anyListOpen) {
    document.getElementById('avatar-container').classList.remove('expanded');
  }
}

async function sendChat() {
  const input = document.getElementById('chat-input');
  const text = input.value.trim();
  if (!text) return;
  
  const messages = document.getElementById('chat-messages');
  messages.innerHTML += `<div class="chat-msg user">${escapeHtml(text)}</div>`;
  chatHistory.push({ role: 'user', text });
  input.value = '';
  
  messages.innerHTML += `<div class="chat-msg ai" id="typing">Typing...</div>`;
  messages.scrollTop = messages.scrollHeight;
  
  try {
    const response = await fetch('/api/twin-chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ message: text, chat_history: chatHistory })
    });
    const data = await response.json();
    document.getElementById('typing')?.remove();
    chatHistory.push({ role: 'ai', text: data.response });
    messages.innerHTML += `<div class="chat-msg ai">${formatResponse(data.response)}</div>`;
    messages.scrollTop = messages.scrollHeight;
  } catch (err) {
    document.getElementById('typing')?.remove();
    messages.innerHTML += `<div class="chat-msg ai">Sorry, I'm having trouble connecting. Please try again.</div>`;
    messages.scrollTop = messages.scrollHeight;
  }
}

function escapeHtml(text) {
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}

function formatResponse(text) {
  return escapeHtml(text)
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.*?)\*/g, '<em>$1</em>')
    .replace(/\n/g, '<br>');
}

function newChat() {
  document.getElementById('chat-messages').innerHTML = `
    <div class="chat-msg ai">Hi Cherry! I'm your Twin. I've prepared your items and I'm ready to help.</div>
  `;
  chatHistory = [];
}

