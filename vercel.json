{
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python@0.6.0"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "main.py"
    }
  ],
  "functions": {
    "main.py": {
      "runtime": "python3.12",
      "maxDuration": 60
    }
  },
  "env": {
    "VERCEL": "1"
  },
  "installCommand": "pip install -r requirements.txt"
}